# Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# Maximum parallel video processing jobs
MAX_PARALLEL_JOBS=2

# Folder for temporary files
TEMP_DIR=./temp

# Device for Whisper (cuda or cpu)
WHISPER_DEVICE=cpu
WHISPER_MODEL=base

# Authorized Admin IDs (comma separated)
ADMIN_IDS=12345678,98765432
